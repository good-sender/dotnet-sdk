# Copy to .env.dev and fill in your dev workspace fixtures.
#   cp .env.example .env.dev
# Then run:
#   bash tests/run.sh dev node                # phase 1: read-only conformance
#   ALLOW_DESTRUCTIVE=1 bash tests/run.sh dev node   # phase 2: full conformance
#
# .env.* is gitignored — never commit your real key.

# ─── Credentials and target ──────────────────────────────────────────
# Required.
GOODSENDER_API_KEY=

# Defaults to the dev server if unset.
BASE_URL=https://api.dev.goodsender.com

# Set to 1 to run the 11 destructive scenarios (sendEmail / sendTemplateEmail /
# requestEmailConsent and their negative-path counterparts). Default 0.
ALLOW_DESTRUCTIVE=0

# ─── Sender domains ──────────────────────────────────────────────────
# A domain you've added to your workspace AND whose DNS is fully in place
# (verification.verified=true). sendEmail / sendTemplateEmail from any other
# domain will be rejected.
VERIFIED_SENDER_DOMAIN=verified.dev.goodsender.com
VERIFIED_SENDER_EMAIL=sender@verified.dev.goodsender.com
VERIFIED_SENDER_NAME="GoodSender SDK Tests"

# A second domain you've added but deliberately left without DNS, so
# verification.verified=false. Used for negative tests that exercise the
# "domain not allowed" error path.
UNVERIFIED_SENDER_DOMAIN=unverified.dev.goodsender.com
UNVERIFIED_SENDER_EMAIL=sender@unverified.dev.goodsender.com

# ─── Recipients (set up in the dashboard, on the verified domain) ────
# Two addresses you've taken through the consent flow and clicked "approve".
# Their consentStatus for VERIFIED_SENDER_DOMAIN must be "granted".
RECIPIENT_GRANTED_1=approved1@sink.example.com
RECIPIENT_GRANTED_2=approved2@sink.example.com

# Two addresses you've taken through the consent flow and clicked "reject".
# Their consentStatus for VERIFIED_SENDER_DOMAIN must be "denied".
RECIPIENT_DENIED_1=denied1@sink.example.com
RECIPIENT_DENIED_2=denied2@sink.example.com

# ─── Template ────────────────────────────────────────────────────────
# An existing template id in your dev workspace. Used by sendTemplateEmail.
TEMPLATE_ID=otp_code

# ─── Notes ───────────────────────────────────────────────────────────
# The "unknown / not yet requested" recipient case is handled by the runner,
# which generates fresh random addresses each run. You do NOT need to seed
# unknown-state addresses in the dashboard — they would just turn into
# "requested" after the first run anyway.
#
# After each destructive run, the addresses passed to requestEmailConsent
# during scenario D6 will be in "requested" state in your workspace. The
# runner emits them at the end so you can clean up manually before the next
# destructive run, per project decision.
